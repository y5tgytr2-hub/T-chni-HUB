-- =====================
-- AUTO FARM
-- =====================

local SelectedFarm = "Common"
local AutoFarm = false

Tabs.Main:AddDropdown("FarmLevel",{
Title = "Farm Level",
Values = TeleportOrder,
Multi = false,
Default = 1
})

Options.FarmLevel:OnChanged(function(v)
SelectedFarm = v
end)

Tabs.Main:AddToggle("AutoFarmToggle",{
Title = "Auto Farm",
Default = false
})

Options.AutoFarmToggle:OnChanged(function(v)
AutoFarm = v
end)

task.spawn(function()

while true do
task.wait(0.6)

if AutoFarm then

    teleport(SelectedFarm)

    task.wait(2)

    local spawner = workspace:FindFirstChild("ItemSpawners")

    if spawner then
        
        local zone = spawner:FindFirstChild(SelectedFarm)

        if zone then

            local items = zone:GetChildren()

            if #items == 0 then
                task.wait(2)
                continue
            end

            for _,item in pairs(items) do

                if not AutoFarm then break end

                local char = player.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")

                if hrp then

                    local part = item:FindFirstChildWhichIsA("BasePart")

                    if part then
                        
                        hrp.CFrame = part.CFrame + Vector3.new(0,3,0)
                        task.wait(0.4)

                        local prompt = item:FindFirstChildWhichIsA("ProximityPrompt",true)

                        if prompt then
                            fireproximityprompt(prompt)
                            task.wait(0.7)
                        end

                    end

                end

            end

        end

    end

end

end

end)

