-- =====================
-- TELEPORT BASE
-- =====================

local function teleportBase()

    local plotName = "Plot_"..player.Name
    local plot = workspace:FindFirstChild(plotName,true)

    if plot then
        
        local pos
        
        if plot:IsA("Model") then
            pos = plot:GetModelCFrame().Position
        elseif plot:IsA("BasePart") then
            pos = plot.Position
        end
        
        if pos then
            
            local char = player.Character or player.CharacterAdded:Wait()
            local hrp = char:WaitForChild("HumanoidRootPart")

            hrp.CFrame = CFrame.new(pos + Vector3.new(0,20,0))
            
        end
        
    end

end

-- =====================
-- TELEPORT ZONE
-- =====================

local function teleport(zoneName)

    local zone = workspace:FindFirstChild(zoneName,true)

    if zone then
        
        local pos
        
        if zone:IsA("Model") then
            pos = zone:GetModelCFrame().Position
        elseif zone:IsA("BasePart") then
            pos = zone.Position
        end
        
        if pos then
            
            local offset = ZoneOffsets[zoneName] or 130
            
            local char = player.Character or player.CharacterAdded:Wait()
            local hrp = char:WaitForChild("HumanoidRootPart")

            hrp.CFrame = CFrame.new(pos + Vector3.new(0,20,offset))
            
        end
        
    end

end

