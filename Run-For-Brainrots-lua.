-- [[ Tora UI | Run For Brainrots - Anti-AFK Switch Update ]]
local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/liebertsx/Tora-Library/main/src/librarynew",true))()
local win = library:CreateWindow("Run For Brainrots💯")

-- SERVICES
local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")
local VirtualUser = game:GetService("VirtualUser")
local player = Players.LocalPlayer

-- VARS
local ZoneOffsets = { Common = 130, Uncommon = 200, Rare = 230, Epic = 270, Legendary = 300, Mythical = 360, Secret = 420, Celestial = 460, Divine = 600, Cosmic = 920 }
local TeleportOrder = { "Common", "Uncommon", "Rare", "Epic", "Legendary", "Mythical", "Secret", "Celestial", "Divine", "Cosmic" }

local AutoReturn = false
local AutoFarm = false
local AntiAFK = false -- ตัวแปรสำหรับสวิตช์ Anti-AFK
local SelectedFarm = "Common"
local SelectedTeleportZone = "Common"

-- =====================
-- FUNCTIONS (CORE)
-- =====================

local function teleportBase()
    local plotName = "Plot_"..player.Name
    local plot = workspace:FindFirstChild(plotName,true)
    if plot then
        local pos = plot:IsA("Model") and plot:GetModelCFrame().Position or plot.Position
        local char = player.Character or player.CharacterAdded:Wait()
        char:WaitForChild("HumanoidRootPart").CFrame = CFrame.new(pos + Vector3.new(0,20,0))
    end
end

local function teleport(zoneName)
    local zone = workspace:FindFirstChild(zoneName,true)
    if zone then
        local pos = zone:IsA("Model") and zone:GetModelCFrame().Position or zone.Position
        local offset = ZoneOffsets[zoneName] or 130
        local char = player.Character or player.CharacterAdded:Wait()
        char:WaitForChild("HumanoidRootPart").CFrame = CFrame.new(pos + Vector3.new(0,20,offset))
    end
end

-- ระบบ Anti-AFK Connection
player.Idled:Connect(function()
    if AntiAFK then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end
end)

-- =====================
-- UI FOLDERS
-- =====================

-- [ Folder: Auto Farm ]
local farmFolder = win:AddFolder("Auto Farm")
farmFolder:AddToggle({ text = "Auto Farm", flag = "auto_farm", callback = function(v) AutoFarm = v end })
farmFolder:AddToggle({ text = "Auto Return Base", flag = "auto_return", callback = function(v) AutoReturn = v end })
farmFolder:AddList({ text = "Farm Level", values = TeleportOrder, callback = function(v) SelectedFarm = v end })

-- [ Folder: Teleport ]
local tpFolder = win:AddFolder("Teleports")
tpFolder:AddButton({ text = "Teleport My Base", callback = function() teleportBase() end })
tpFolder:AddList({ text = "Choose Zone", values = TeleportOrder, callback = function(v) SelectedTeleportZone = v end })
tpFolder:AddButton({ text = "Teleport to Selected", callback = function() teleport(SelectedTeleportZone) end })

-- [ Folder: Settings ]
local settingsFolder = win:AddFolder("Settings")

-- 1) Anti-AFK (เปลี่ยนเป็นสวิตช์ Toggle)
settingsFolder:AddToggle({
    text = "Anti-AFK",
    flag = "anti_afk",
    state = false,
    callback = function(v)
        AntiAFK = v
        print("Anti-AFK is now: " .. (v and "Enabled" or "Disabled"))
    end
})

-- 2) Rejoin & Server Hop (ยังเป็นปุ่มเหมือนเดิม)
settingsFolder:AddButton({ text = "Rejoin Server", callback = function() TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player) end })
settingsFolder:AddButton({ text = "Server Hop", callback = function()
    local servers = {}
    local req = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Desc&limit=100"))
    for _, s in pairs(req.data) do if s.playing < s.maxPlayers and s.id ~= game.JobId then table.insert(servers, s.id) end end
    if #servers > 0 then TeleportService:TeleportToPlaceInstance(game.PlaceId, servers[math.random(1, #servers)], player) end
end})

settingsFolder:AddSlider({ text = "FOV", min = 70, max = 120, callback = function(v) workspace.CurrentCamera.FieldOfView = v end })

-- =====================
-- LOOPS (AUTO FARM LOGIC)
-- =====================

task.spawn(function()
    while true do
        task.wait(0.4)
        if AutoReturn and player.Character and player.Character:FindFirstChild("CarryVisuals") then
            teleport("Common")
            task.wait(0.5)
            teleportBase()
        end
    end
end)

task.spawn(function()
    while true do
        task.wait(0.6)
        if AutoFarm then
            teleport(SelectedFarm)
            task.wait(1.5)
            local spawner = workspace:FindFirstChild("ItemSpawners")
            if spawner and spawner:FindFirstChild(SelectedFarm) then
                for _, item in pairs(spawner[SelectedFarm]:GetChildren()) do
                    if not AutoFarm then break end
                    local part = item:FindFirstChildWhichIsA("BasePart")
                    if part and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        player.Character.HumanoidRootPart.CFrame = part.CFrame + Vector3.new(0,3,0)
                        task.wait(0.4)
                        local prompt = item:FindFirstChildWhichIsA("ProximityPrompt",true)
                        if prompt then fireproximityprompt(prompt) task.wait(0.6) end
                    end
                end
            end
        end
    end
end)

win:AddLabel({ text = "Script By : T-chni Hub V.1.7" })

library:Init()
