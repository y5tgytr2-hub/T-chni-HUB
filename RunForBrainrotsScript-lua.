-- =====================
-- CORE FUNCTIONS
-- =====================
local function collectAllMoney()
    local plotName = "Plot_"..player.Name
    local plot = workspace:FindFirstChild(plotName, true)
    if plot then
        for f = 1, 3 do 
            local floor = plot:FindFirstChild("Floor"..f)
            if floor and floor:FindFirstChild("Slots") then
                for s = 1, 10 do
                    local slot = floor.Slots:FindFirstChild("Slot"..s)
                    if slot and slot:FindFirstChild("CollectTouch") then
                        local touchPart = slot.CollectTouch
                        firetouchinterest(player.Character.HumanoidRootPart, touchPart, 0)
                        task.wait()
                        firetouchinterest(player.Character.HumanoidRootPart, touchPart, 1)
                    end
                end
            end
        end
    end
end

-- ฟังก์ชันวาร์ปไป SpeedStand (โหมดเร็ว/Safe Zone)
local function teleportSpeedStand()
    local stand = workspace:FindFirstChild("SpeedStand")
    if stand then
        local char = player.Character or player.CharacterAdded:Wait()
        local hrp = char:WaitForChild("HumanoidRootPart")
        local pos = stand:IsA("Model") and stand:GetModelCFrame() or stand.CFrame
        hrp.CFrame = pos + Vector3.new(0, 7, 0)
    end
end

local function teleportBase()
    local plotName = "Plot_"..player.Name
    local plot = workspace:FindFirstChild(plotName,true)
    if plot then
        local pos = plot:IsA("Model") and plot:GetModelCFrame().Position or plot.Position
        local char = player.Character or player.CharacterAdded:Wait()
        char:WaitForChild("HumanoidRootPart").CFrame = CFrame.new(pos + Vector3.new(0,20,0))
    end
end

local function teleportZone(zoneName)
    local zone = workspace:FindFirstChild(zoneName,true)
    if zone then
        local pos = zone:IsA("Model") and zone:GetModelCFrame().Position or zone.Position
        local offset = ZoneOffsets[zoneName] or 130
        local char = player.Character or player.CharacterAdded:Wait()
        char:WaitForChild("HumanoidRootPart").CFrame = CFrame.new(pos + Vector3.new(0,20,offset))
    end
end

