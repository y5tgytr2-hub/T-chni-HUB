-- 1. Money Collection Loop
task.spawn(function()
    while true do
        if _G.AutoCollectMoney then pcall(collectAllMoney) end
        task.wait(_G.CollectDelay)
    end
end)

-- 2. Return Base Loop
task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.AutoReturn and player.Character and player.Character:FindFirstChild("CarryVisuals") then
            if _G.ReturnMode == "Fast⚡" then
                teleportSpeedStand()
            else
                teleportZone("Common")
                task.wait(0.5)
                teleportSpeedStand()
            end
            task.wait(1)
        end
    end
end)

-- 3. Auto Farm Loop
task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.AutoFarm then
            pcall(function()
                teleportZone(_G.SelectedFarm)
                task.wait(1.5)
                local spawner = workspace:FindFirstChild("ItemSpawners")
                if spawner and spawner:FindFirstChild(_G.SelectedFarm) then
                    for _, item in pairs(spawner[_G.SelectedFarm]:GetChildren()) do
                        if not _G.AutoFarm then break end
                        local part = item:FindFirstChildWhichIsA("BasePart")
                        if part and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                            player.Character.HumanoidRootPart.CFrame = part.CFrame + Vector3.new(0,3,0)
                            task.wait(0.3)
                            local prompt = item:FindFirstChildWhichIsA("ProximityPrompt",true)
                            if prompt then fireproximityprompt(prompt) task.wait(0.5) end
                        end
                    end
                end
            end)
        end
    end
end)

-- 4. FOV Persistence Loop
task.spawn(function()
    while true do
        if _G.LoopFOV then
            pcall(function() workspace.CurrentCamera.FieldOfView = _G.FOVValue end)
        end
        task.wait(0.01)
    end
end)

