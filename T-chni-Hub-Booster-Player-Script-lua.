      if not Value then
          local hum = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
          if hum then hum.WalkSpeed = lastDefaultSpeed end
      end
   end,
})

MoveTab:CreateSection("🚀 JumpPower Settings | การตั้งค่า Jumppower")
MoveTab:CreateParagraph({
    Title = "Info Jumppower | ข้อมูล Jumppower", 
    Content = "Your jump value is higher; the higher the value, the higher your jump will be | ค่าการกระโดดของคุณสูงขึ้น ยิ่งค่าสูงเท่าไหร่ การกระโดดของคุณก็จะยิ่งสูงขึ้นเท่านั้น"
})
MoveTab:CreateInput({
   Name = "Set JumpPower | ตั้งค่า Jumppower",
   PlaceholderText = "Default: 50 | ปกติ 50",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text) _G.CustomJump = tonumber(Text) or 50 end,
})
MoveTab:CreateToggle({
   Name = "Enable Set JumpPower | ใช้งาน ตั้งค่า Jumppower",
   CurrentValue = false,
   Flag = "JPToggle",
   Callback = function(Value) 
      _G.JumpPowerEnabled = Value 
      -- ถ้าปิด ให้รีเซ็ตกลับเป็นค่าเดิมทันที
      if not Value then
          local hum = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
          if hum then hum.JumpPower = lastDefaultJump end
