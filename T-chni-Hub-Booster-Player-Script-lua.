})
MoveTab:CreateInput({
   Name = "Set WalkSpeed | ตั้งค่า Walkspeed",
   PlaceholderText = "Default: 16 | ปกติ 16",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text) _G.CustomSpeed = tonumber(Text) or 16 end,
})
MoveTab:CreateToggle({
   Name = "Enable WalkSpeed | ใช้งาน Walkspeed",
   CurrentValue = false,
   Flag = "WSToggle",
   Callback = function(Value) 
