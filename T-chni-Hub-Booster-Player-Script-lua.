-- ==========================================
-- TAB 2: ESP
-- ==========================================
local ESPTab = Window:CreateTab("ESP | การมองละทุ", 4483362458)
ESPTab:CreateParagraph({
    Title = "Info Esp | ข้อมูล Esp", 
    Content = "Esp is Visibility of the player | Esp คือ การมองเห็นของผู้เล่น "
})
local function ApplyESP(player)
    player.CharacterAdded:Connect(function(char)
        if _G.ESPEnabled then
            task.wait(0.5)
            local highlight = Instance.new("Highlight")
            highlight.Name = "GeminiESP"
            highlight.FillColor = Color3.fromRGB(255, 0, 0)
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
            highlight.Parent = char
        end
    end)
    
    if player.Character and _G.ESPEnabled then
        local highlight = player.Character:FindFirstChild("GeminiESP") or Instance.new("Highlight")
        highlight.Name = "GeminiESP"
        highlight.Parent = player.Character
    end
end

ESPTab:CreateToggle({
   Name = "Enable Player ESP | ใช้งาน Esp",
   CurrentValue = false,
   Flag = "ESPToggle",
   Callback = function(Value)
      _G.ESPEnabled = Value
      if Value then
          for _, player in pairs(game.Players:GetPlayers()) do
              if player ~= game.Players.LocalPlayer then ApplyESP(player) end
          end
      else
          -- ลบ ESP ออกทันทีเมื่อปิด
          for _, player in pairs(game.Players:GetPlayers()) do
              if player.Character and player.Character:FindFirstChild("GeminiESP") then
                  player.Character.GeminiESP:Destroy()
              end
          end
      end
   end,
})

-- ==========================================
-- BACKEND SYSTEMS
-- ==========================================

-- 1. Loop บังคับค่า (จะทำงานเฉพาะตอนเปิด Toggle เท่านั้น)
task.spawn(function()
    while true do
        task.wait(0.1)
        pcall(function()
            local char = game.Players.LocalPlayer.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hum then
                if _G.WalkSpeedEnabled then 
                    hum.WalkSpeed = _G.CustomSpeed 
                end
                if _G.JumpPowerEnabled then 
                    hum.UseJumpPower = true
                    hum.JumpPower = _G.CustomJump 
                end
            end
        end)
    end
end)

-- 2. Infinite Jump
game:GetService("UserInputService").JumpRequest:Connect(function()
    if _G.InfiniteJumpEnabled then
        pcall(function()
            game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
        end)
    end
end)

-- 3. ระบบจัดการเมื่อตัวละครเกิดใหม่
game.Players.LocalPlayer.CharacterAdded:Connect(function(newChar)
    SaveDefaults() -- บันทึกค่าพื้นฐานใหม่ (เผื่อบางแมพเปลี่ยนค่าตอนเกิด)
    local hum = newChar:WaitForChild("Humanoid", 5)
    if hum then
        task.wait(0.6)
        if _G.WalkSpeedEnabled then hum.WalkSpeed = _G.CustomSpeed end
        if _G.JumpPowerEnabled then 
            hum.UseJumpPower = true
            hum.JumpPower = _G.CustomJump 
        end
    end
end)

-- 4. ระบบ ESP สำหรับคนเข้าใหม่
game.Players.PlayerAdded:Connect(function(player)
    ApplyESP(player)
end)

Rayfield:Notify({
