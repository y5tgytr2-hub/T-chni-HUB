-- TAB 1: MOVEMENT CONTROL
-- ==========================================
local MoveTab = Window:CreateTab("Movement", 4483362458)

MoveTab:CreateSection("🏃 WalkSpeed Settings | การตั้งค่า Walkspeed")
MoveTab:CreateParagraph({
