-- [[ GLOBAL VARIABLES ]]
_G.WalkSpeedEnabled = false
_G.CustomSpeed = 16
_G.JumpPowerEnabled = false
_G.CustomJump = 50
_G.InfiniteJumpEnabled = false
_G.ESPEnabled = false

-- เก็บค่าเริ่มต้นของตัวละครไว้ (Reset Values)
local lastDefaultSpeed = 16
local lastDefaultJump = 50

local function SaveDefaults()
    local char = game.Players.LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then
        -- บันทึกค่าที่เซิร์ฟเวอร์หรือเกมตั้งมาให้ตอนแรก
        lastDefaultSpeed = hum.WalkSpeed
        lastDefaultJump = hum.JumpPower
    end
end
SaveDefaults()

